          "a": -930.8,
          "b": 2.94,
          "c": 0.808,
          "floor": 148.5,
          "weighted_r_squared": 0.809,
          "note": "equal-per-plant weighting; recommended for 'typical plant' framing"
        },
        "v6_per_observation": {
          "a": -1030.8,
          "b": 2.307,
          "c": 0.708,
          "floor": 137.8,
